# PostgreSQL
POSTGRES_USER=docflow
POSTGRES_PASSWORD=docflow_secret
POSTGRES_DB=docflow
DATABASE_URL=postgresql://docflow:docflow_secret@db:5432/docflow

# Bitrix GPT через AI Router VibeCode (OpenAI-совместимый /chat/completions)
# API_KEY — персональный ключ vibe_api_… из раздела «Ключи API» VibeCode
API_KEY=vibe_api_your_key_here
BASE_URL=https://vibecode.bitrix24.tech/v1
MODEL=bitrix/bitrixgpt-5.5

# Базовый URL самого backend-приложения (для webhook_url и внешних ссылок)
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000

# GitHub OAuth App (legacy: user-логин + fallback доступ к репам во время миграции)
# Создать: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# Callback URL собирается автоматически как ${FRONTEND_BASE_URL}/auth/github/callback
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# GitHub App (точечный доступ к выбранным репам через installation-токены)
# Создать: GitHub → Settings → Developer settings → GitHub Apps → New GitHub App
# Permissions: Contents=RW, Metadata=RO; Events: Push, Installation, Installation repositories
# Webhook URL: ${APP_BASE_URL}/webhook/github/app
# Приватный ключ (PEM) можно хранить одной строкой с литеральными \n — он развернётся автоматически
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# Тестовая БД (только для pytest, не используется в dev/prod)
DATABASE_TEST_URL=postgresql+asyncpg://docflow:docflow_secret@localhost:5433/docflow_test

# JWT session secret (случайная строка, минимум 32 символа) — подписывает сессии
SESSION_SECRET=change_me_to_a_random_32_char_string

# Ключ шифрования секретов в БД (GitHub-токены, webhook-секреты) — ОТДЕЛЬНЫЙ от SESSION_SECRET.
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_generate_a_fernet_key
